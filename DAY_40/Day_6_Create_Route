// form ke data ko parse karne ke liye middleware use karna padega
app.use(express.urlencoded({extended:true})); 

//  Create Route

app.post("/chats",(req,res)=>{
    // form ke data ko receive karna/access karna padega
    let{from,to,msg}=req.body;
    let newChat=new Chat({
        from:from,
        to:to,
        msg:msg,
        create_at: new Date(),
    });
    // chat save kara lete hai
    newChat
        .save()
        .the(res=>{
            console.log("chat was saved")
        })
        .catch(err=>{console.log(err)
        });
    // console.log(newChat);
    res.redirect("/chats"); // redirect karna padega chats route pe jaha pe sare chats show honge
});
